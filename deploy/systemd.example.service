[Unit]
Description=ADSENSE_SAAS_AUTO Gunicorn
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/ADSENSE_SAAS_AUTO
Environment="PATH=/var/www/ADSENSE_SAAS_AUTO/.venv/bin"
ExecStart=/var/www/ADSENSE_SAAS_AUTO/.venv/bin/gunicorn -w 2 -b 127.0.0.1:8000 wsgi:app
Restart=always

[Install]
WantedBy=multi-user.target
